 */

use GetOpt\GetOpt;
use GetOpt\Command;
use GetOpt\Option;
use Piko\I18n;
use Piko\UserModule\Models\User;
use Piko\UserModule\Rbac;

require $GLOBALS['_composer_autoload_path'] ?? __DIR__ . '/../vendor/autoload.php';

function getPDO(): PDO
{
    $username = getenv('DB_USERNAME') ? getenv('DB_USERNAME') : null;
    $password = getenv('DB_PASSWORD') ? getenv('DB_PASSWORD') : null ;
    try {
        $pdo = new PDO(getenv('DSN'), $username, $password);
        // Test the connection (optional: simple query)
        $pdo->query('SELECT 1');
    } catch (PDOException $e) {
        fwrite(STDERR, "Database connection failed: " . $e->getMessage() . "\n");
        exit(1);
    }

    return $pdo;
}

function successMsg(string $message): string
{
    $green = "\033[32m";
    $reset = "\033[0m";

    return $green . $message . $reset;
}

function errorMsg(string $message): string
{
    $red = "\033[31m";
    $reset = "\033[0m";

    return $red . $message . $reset;
}

function createUserCommand(PDO $db, array $options = []): int
{
    $interactive = (bool) ($options['interactive'] ?? false);

    if ($interactive) {
        echo "=== Create a new admin user ===\n";

        $options['name'] = readline("Enter Full Name: ");
        $options['email'] = readline("Enter Email Address: ");
        $options['username'] = readline("Choose a Username: ");
        $options['password'] = readline("Choose a Password: ");
    }

    Rbac::setPDO($db);

    if (!Rbac::roleExists('admin')) {
        echo "Admin role does not exist. Creating 'admin' role...\n";
        Rbac::createRole('admin');
    }

    $user = new User($db);
    $user->scenario = User::SCENARIO_ADMIN;
    $user->bind($options);

    if ($user->isValid() && $user->save()) {

        Rbac::assignRole($user->id, 'admin');
        echo successMsg("Success! The admin user '{$user->username}' was created.\n
        You can now log in with this account.\n");

        return 0;
    }

    echo errorMsg("User creation failed for the following reasons:
    \n" . implode("\n- ", $user->getErrors()) . PHP_EOL);

    return 1;
}

$workingDir = getcwd();

if (file_exists($workingDir . '/env.php')) {
    foreach (require $workingDir . '/env.php' as $key => $val) {
        putenv("{$key}={$val}");
    }
}

$i18n = new I18n();
I18n::setInstance($i18n);

$getopt = new GetOpt([
    Option::create('h', 'help')->setDescription('Displays help')
]);

$getopt->addCommands([
    Command::create('user:create', 'createUserCommand', [
    Option::create('n', 'name', GetOpt::OPTIONAL_ARGUMENT)->setDescription('Full name of the user'),
    Option::create('e', 'email', GetOpt::REQUIRED_ARGUMENT)->setDescription('Email address for the user'),
    Option::create('u', 'username', GetOpt::REQUIRED_ARGUMENT)->setDescription('Username for user login'),
    Option::create('p', 'password', GetOpt::REQUIRED_ARGUMENT)->setDescription('Password for the user account'),
        Option::create('i', 'interactive')->setDescription('Prompt for all user details interactively'),
    ])->setShortDescription('Create an admin user'),
]);

$getopt->process();

/** @var Command $command */
$command = $getopt->getCommand();

if ($getopt->getOption('h')) {
    echo $getopt->getHelpText();
    exit(0);
}

if (!$command) {
    echo "No command given.\n";
    echo $getopt->getHelpText();
    exit(0);

} else {

    $handler = $command->getHandler();
    $pdo = getPDO();
    $code = -1;

    if ($handler === 'createUserCommand') {
        $code = createUserCommand($pdo, $getopt->getOptions());
    }

    exit($code);
}
